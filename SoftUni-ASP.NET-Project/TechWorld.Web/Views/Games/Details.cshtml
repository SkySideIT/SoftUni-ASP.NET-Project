@using TechWorld.GCommon
@model TechWorld.Web.ViewModels.GameDetailsViewModel

@{
	ViewData["Title"] = Model.Title;
}

<div class="container py-5">
	<div class="row justify-content-center">
		<div class="col-lg-8 text-center">
			<div class="card bg-dark border-0 shadow-sm mb-4 mx-auto" style="max-width: 500px;">
				<img src="@Model.ImageUrl" alt="@Model.Title" class="card-img-top rounded">
			</div>

			<h1 class="display-5 fw-bold mb-3">@Model.Title</h1>

			<div class="mb-3">
				<span class="badge bg-primary me-2">
					<i class="bi bi-controller"></i> @Model.Platform
				</span>
				<span class="badge bg-secondary me-2">
					<i class="bi bi-bookmark"></i> @Model.Genre
				</span>
				<span class="badge bg-info text-dark">
					<i class="bi bi-building"></i> @Model.Publisher
				</span>
			</div>

			<p class="lead text-muted mb-2">
				<i class="bi bi-calendar3 me-2"></i>
				Released on <strong>@Model.ReleaseDate.ToString("MMMM dd, yyyy", System.Globalization.CultureInfo.InvariantCulture)</strong>
			</p>

			<hr>

			<p class="fs-5 lh-lg mb-4">
				@Model.Description
			</p>

			<span class="h3 fw-bold text-success d-block mb-4">$@Model.Price.ToString("0.00")</span>

			<div class="mt-4">
				<a asp-controller="Home" asp-action="Index" class="btn btn-link">
					<i class="bi bi-arrow-left"></i> Back to Home
				</a>
			</div>
		</div>
	</div>
</div>