@model TechWorld.Web.ViewModels.GamesIndexViewModel

@{
	ViewData["Title"] = "Games";
}

<section class="py-5" style="background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);">
	<div class="container">
		<h1 class="display-4 fw-bold text-center mb-4" style="color: #ffc107">Browse Games</h1>
		<p class="lead text-center text-white mb-5">Explore our collection of the latest and greatest games!</p>
	</div>
</section>

<section class="container py-5">

	<div class="row g-4">

		<form method="get" class="mb-4">
			<div class="row">

				<div class="col-md-4">
					<input type="text"
						   name="searchTerm"
						   value="@Model.SearchTerm"
						   class="form-control"
						   placeholder="Search by title..." />
				</div>

				<div class="col-md-3">
					<select name="genreId" class="form-select">
						<option value="">All Genres</option>

						@foreach (var genre in Model.Genres)
						{
							<option value="@genre.Id">@genre.Name</option>
						}

					</select>
				</div>

				<div class="col-md-3">
					<select name="platformId" class="form-select">
						<option value="">All Platforms</option>

						@foreach (var platform in Model.Platforms)
						{
							<option value="@platform.Id">@platform.Name</option>
						}

					</select>
				</div>

				<div class="col-md-2">
					<button class="btn btn-warning w-100 ">
						Search
					</button>
				</div>

			</div>
		</form>

		@foreach (var game in Model.Games)
		{
			<div class="col-md-4 col-sm-6">
				<div class="card h-100 shadow-lg border-0">
					<img src="@game.ImageUrl" class="card-img-top" alt="@game.Title" style="height: 220px; object-fit: cover;">
					<div class="card-body d-flex flex-column">
						<h5 class="card-title fw-bold">@game.Title</h5>
						<p class="card-text text-muted mb-2">
							@(game.Description.Length > 90 ? game.Description.Substring(0, 90) + "..." : game.Description)
						</p>
						<ul class="list-group list-group-flush mb-3">
							<li class="list-group-item"><strong>Genre:</strong> @game.Genre</li>
							<li class="list-group-item"><strong>Platform:</strong> @game.Platform</li>
							<li class="list-group-item"><strong>Publisher:</strong> @game.Publisher</li>
							<li class="list-group-item"><strong>Release Date:</strong> @game.ReleaseDate.ToString("yyyy-MM-dd")</li>
							<li class="list-group-item"><strong>Price:</strong> $@game.Price.ToString("F2")</li>
						</ul>
						@if (!game.InWishlist)
						{
							<form asp-controller="Wishlist" asp-action="Add" method="post">
								<input type="hidden" name="gameId" value="@game.Id" />
								<button class="btn btn-primary mt-auto w-100">⭐ Add to Wishlist</button>
							</form>
						}
						else
						{
							<span class="badge bg-warning" style="color: black">✅ In Wishlist</span>
						}

						<hr />

						@if (!game.InCart)
						{
							<form asp-controller="Cart" asp-action="Add" method="post">
								<input type="hidden" name="gameId" value="@game.Id" />
								<button type="submit" class="btn btn-success mt-auto w-100">Put in Cart</button>
							</form>
						}
						else
						{
							<button class="btn btn-secondary" disabled>
								Already in Cart
							</button>
						}

					</div>
				</div>
			</div>
		}
	</div>
</section>
