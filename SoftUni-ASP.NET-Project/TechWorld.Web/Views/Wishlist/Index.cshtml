@model IEnumerable<GameDetailsViewModel>

<div class="container mt-5">
    <div class="d-flex justify-content-center">

        <div class="card shadow-sm border-0"
             style="width:100%; max-width:1000px; background-color:#FFC300">

            <div class="card-body p-4">

                <h1 class="text-center mb-4"><strong>My Wishlist</strong></h1>

                <div class="row g-4">

                    @foreach (var game in Model)
                    {
                        <div class="col-md-4">

                            <div class="card h-100 shadow-sm">

                                <img src="@game.ImageUrl"
                                     class="card-img-top"
                                     style="height:200px; object-fit:cover;"
                                     onerror="this.src='/images/no-image.png'" />

                                <div class="card-body">

                                    <h5 class="card-title">@game.Title</h5>

                                    <p class="card-text">
                                        <strong>Genre:</strong> @game.Genre <br />
                                        <strong>Platform:</strong> @game.Platform <br />
                                        <strong>Publisher:</strong> @game.Publisher
                                    </p>

                                    <p class="fw-bold">$@game.Price</p>

                                    <a asp-controller="Games"
                                       asp-action="Details"
                                       asp-route-id="@game.Id"
                                       class="btn btn-dark btn-sm">
                                        Details
                                    </a>

                                    <a asp-controller="Wishlist"
                                       asp-action="Remove"
                                       asp-route-gameId="@game.Id"
                                       class="btn btn-danger btn-sm">
                                        Remove
                                    </a>

                                </div>

                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>
</div>