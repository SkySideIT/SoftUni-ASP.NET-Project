@model IEnumerable<WishlistViewModel>

@{
    ViewData["Title"] = "My Wishlist";
}

<div class="container mt-5">
    <div class="d-flex justify-content-center">
        <div class="card shadow-sm border-0" style="width: 100%; max-width: 1000px; background-color: #FFC300">
            <div class="card-body p-4">

                <h1 class="text-center mb-4"><strong>My Wishlist</strong></h1>

                @if (!Model.Any())
                {
                    <div class="text-center">
                        <p class="lead">Your wishlist is empty.</p>

                        <a asp-controller="Games"
                           asp-action="Index"
                           class="btn btn-primary mt-3">
                            Browse Games
                        </a>
                    </div>
                }
                else
                {
                    foreach (var game in Model)
                    {
                        <div class="card mb-4 shadow-sm">
                            <div class="row g-0">

                                <div class="col-md-4">
                                    <img src="@(game.ImageUrl ?? "/images/no-image.png")"
                                         class="img-fluid rounded-start"
                                         style="height:100%; object-fit:cover;" />
                                </div>

                                <div class="col-md-8">
                                    <div class="card-body">

                                        <h4 class="card-title">@game.Title</h4>

                                        <p class="card-text">
                                            <strong>Genre:</strong> @game.Genre <br />
                                            <strong>Platform:</strong> @game.Platform <br />
										    <strong>Publisher:</strong> @game.Publisher <br />
                                            <strong style="font-size: larger">Price:</strong> $@game.Price
                                        </p>

                                        <div class="mt-3">

                                            <a asp-controller="Games"
                                               asp-action="Details"
                                               asp-route-id="@game.Id"
                                               class="btn btn-dark btn-sm">
                                                Details
                                            </a>

                                            <form asp-controller="Wishlist"
                                                  asp-action="Remove"
                                                  method="post"
                                                  class="d-inline">

                                                <input type="hidden" name="gameId" value="@game.Id" />

                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    Remove
                                                </button>
                                            </form>

                                        </div>

                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                }

            </div>
        </div>
    </div>
</div>