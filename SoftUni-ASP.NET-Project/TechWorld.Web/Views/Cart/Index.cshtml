@model IEnumerable<CartViewModel>

@{
	ViewData["Title"] = "My Cart";
}

<div class="container mt-5">
	<div class="d-flex justify-content-center">
		<div class="card shadow-sm border-0" style="width: 100%; max-width: 1000px; background-color: #FFC300">
			<div class="card-body p-4">

				<h1 class="text-center mb-4"><strong>Your Shopping Cart</strong></h1>

				@if (TempData["SuccessMessage"] != null)
				{
					<div class="alert alert-success text-center">
						@TempData["SuccessMessage"]
					</div>
				}

				@if (!Model.Any())
				{
					<div class="text-center mt-5">
						<h4>Your cart is empty 🛒</h4>
						<a asp-controller="Games" asp-action="Index" class="btn btn-primary mt-3">
							Browse Games
						</a>
					</div>
				}
				else
				{
					<div class="row g-4">

						@foreach (var game in Model)
						{
							<div class="col-12">
								<div class="card shadow-sm border-0">
									<div class="row g-0 align-items-center">

										<div class="col-md-3">
											<img src="@game.ImageUrl"
												 class="img-fluid rounded-start"
												 alt="@game.Title"
												 style="height: 150px; object-fit: cover; width: 100%;">
										</div>

										<div class="col-md-6">
											<div class="card-body">
												<h5 class="card-title">@game.Title</h5>
												<p class="card-text text-muted">
													Price: <strong>$@game.Price</strong>
												</p>
											</div>
										</div>

										<div class="col-md-3 text-end pe-4">
											<form asp-action="Remove" method="post">
												<input type="hidden" name="gameId" value="@game.Id" />
												<button class="btn btn-danger">
													Remove
												</button>
											</form>
										</div>

									</div>
								</div>
							</div>
						}

					</div>

					<div class="mt-5 p-4 bg-light rounded shadow-sm">

						<div class="d-flex justify-content-between align-items-center">
							<h4 class="mb-0">
								Total: <strong>$@ViewBag.Total</strong>
							</h4>

							<form asp-action="Purchase" method="post">
								<button class="btn btn-success btn-lg">
									Buy Now
								</button>
							</form>
						</div>

					</div>
				}

			</div>
		</div>
	</div>
</div>